{
  "name": "blaniel-core",
  "version": "0.1.0",
  "description": "Emotional AI engine - OCC + Plutchik emotional pipeline, vector memory, psychological behaviors, multi-agent worlds, and LLM orchestration",
  "license": "MIT",
  "private": false,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' DEV_MODE=true next dev --turbopack",
    "dev:setup": "prisma generate && prisma db push --accept-data-loss && tsx prisma/seed-dev.ts",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' prisma generate && NODE_OPTIONS='--max-old-space-size=8192' next build",
    "start": "NODE_ENV=production NODE_OPTIONS='--max-old-space-size=4096' next start",
    "lint": "eslint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "db:prepare": "prisma generate && prisma db push --accept-data-loss",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:dev": "tsx prisma/seed-dev.ts",
    "db:seed:worlds": "tsx scripts/seed-predefined-worlds.ts",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset && npm run db:seed",
    "db:setup": "prisma generate && prisma db push --accept-data-loss && npm run db:seed",
    "security:audit": "./scripts/security-audit.sh",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.921.0",
    "@aws-sdk/s3-request-presigner": "^3.922.0",
    "@better-auth/expo": "^1.4.18",
    "@elevenlabs/elevenlabs-js": "^2.19.0",
    "@google/generative-ai": "^0.24.1",
    "@gradio/client": "^2.0.0-dev.0",
    "@paddle/paddle-node-sdk": "^3.3.0",
    "@prisma/client": "^6.19.1",
    "@react-email/components": "^0.5.7",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.35.6",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.18",
    "bullmq": "^5.63.0",
    "date-fns": "^4.1.0",
    "expo-server-sdk": "^4.0.0",
    "google-auth-library": "^10.5.0",
    "hnswlib-node": "^3.0.0",
    "ioredis": "^5.8.2",
    "jose": "^6.1.0",
    "jspdf": "^4.1.0",
    "mercadopago": "^2.9.0",
    "nanoid": "^5.1.5",
    "ngeohash": "^0.6.3",
    "next": "^16.1.1",
    "nodemailer": "^8.0.1",
    "openai": "^6.3.0",
    "pino": "^10.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-email": "^4.3.2",
    "resend": "^6.4.0",
    "sharp": "^0.34.4",
    "socket.io": "^4.8.1",
    "string-similarity": "^4.0.4",
    "stripe": "^19.2.0",
    "swagger-jsdoc": "^6.2.8",
    "undici": "^7.16.0",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "jsdom": "^27.0.0",
    "null-loader": "^4.0.1",
    "prisma": "^6.17.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
