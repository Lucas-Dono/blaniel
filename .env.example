# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# BLANIEL PLAYGROUND - Minimal Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# This file contains the MINIMUM configuration needed to run the playground.
#
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Get free API keys (see links below)
# 3. Run: npm run dev:setup && npm run dev
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🗄️ DATABASE (Required)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Quick setup with Docker:
# docker run -d --name blaniel-db -e POSTGRES_PASSWORD=blaniel -e POSTGRES_DB=blaniel -p 5432:5432 postgres:16
#
# Free cloud options: Neon (https://neon.tech), Supabase (https://supabase.com)
DATABASE_URL="postgresql://postgres:blaniel@localhost:5432/blaniel"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 💾 REDIS (Required for production, optional for playground)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Docker: docker run -d --name blaniel-redis -p 6379:6379 redis:7
# Cloud: Upstash (https://upstash.com) - Free tier available
# Leave commented for local dev without Redis
REDIS_URL="redis://localhost:6379"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🤖 LLM API KEYS (Required - Get free tiers)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Google Gemini - Emotional orchestration (FREE tier available)
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY="your-google-ai-key-here"

# Venice AI - Character response generation (FREE tier available)
# Get key: https://venice.ai/settings/api/keys
VENICE_API_KEY="your-venice-ai-key-here"

# OpenAI - Embeddings for memory system (Paid, ~$0.0001/request)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY="your-openai-key-here"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔐 SECURITY (Auto-generated on first run if empty)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Leave empty - will be auto-generated. Or generate manually:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MESSAGE_ENCRYPTION_KEY=""

# Leave empty - will be auto-generated. Or generate manually:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=""

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔄 ALTERNATIVE LLM PROVIDERS (Optional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# By default: Gemini (orchestrator) + Venice (writer)
# You can use local LLMs (100% free, private, offline) or other providers

# Option 1: Local LLMs (Ollama, LM Studio, LocalAI, Text Gen WebUI)
# Install Ollama: https://ollama.com → Run: ollama pull llama3.1
# LOCAL_LLM_TYPE="ollama"
# LOCAL_LLM_URL="http://localhost:11434"
# LOCAL_LLM_MODEL="llama3.1"

# Option 2: Other cloud providers (requires code modification)
# Together.ai: https://together.ai
# TOGETHER_API_KEY=""
#
# OpenRouter (100+ models): https://openrouter.ai
# OPENROUTER_API_KEY=""
#
# Grok (xAI): https://x.ai/api
# GROK_API_KEY=""
#
# Anthropic Claude: https://anthropic.com
# ANTHROPIC_API_KEY=""

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚙️ PLAYGROUND MODE (Enabled by default)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DEV_MODE bypasses authentication for testing. NEVER use in production.
DEV_MODE="true"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🎨 OPTIONAL FEATURES (Leave commented unless needed)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Voice (ElevenLabs TTS)
# ELEVENLABS_API_KEY=""

# Image Generation (Multiple providers)
# AI_HORDE_API_KEY=""
# HUGGINGFACE_API_KEY_1=""

# Email Notifications
# MAIL_HOST=""
# MAIL_PORT="465"
# MAIL_USER=""
# MAIL_PASSWORD=""
# MAIL_FROM_ADDRESS="noreply@example.com"
